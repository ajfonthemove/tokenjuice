{
  "id": "service/netstat",
  "family": "service-network-state",
  "description": "Compact netstat output while preserving socket rows.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["netstat"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 14,
    "tail": 4
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 16,
    "tail": 12
  },
  "counters": [
    {
      "name": "socket",
      "pattern": ".+"
    }
  ]
}
