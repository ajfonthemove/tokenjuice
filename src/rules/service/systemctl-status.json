{
  "id": "service/systemctl-status",
  "family": "service-state",
  "description": "Compact systemctl status output while preserving active state and failure lines.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["systemctl"],
    "argvIncludes": [["status"]]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 12,
    "tail": 10
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 16,
    "tail": 14
  },
  "counters": [
    {
      "name": "error",
      "pattern": "failed|inactive|dead|error",
      "flags": "i"
    }
  ]
}
