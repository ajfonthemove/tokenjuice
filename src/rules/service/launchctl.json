{
  "id": "service/launchctl",
  "family": "service-state",
  "description": "Compact launchctl output while preserving labels and status rows.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["launchctl"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 12,
    "tail": 6
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 14,
    "tail": 12
  },
  "counters": [
    {
      "name": "service",
      "pattern": ".+"
    }
  ]
}
