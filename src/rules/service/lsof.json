{
  "id": "service/lsof",
  "family": "service-open-files",
  "description": "Compact lsof output while preserving open-file rows.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["lsof"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 14,
    "tail": 4
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 16,
    "tail": 12
  },
  "counters": [
    {
      "name": "entry",
      "pattern": ".+"
    }
  ]
}
