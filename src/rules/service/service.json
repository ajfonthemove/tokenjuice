{
  "id": "service/service",
  "family": "service-state",
  "description": "Compact service command output while preserving status and failure lines.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["service"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 12,
    "tail": 8
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 14,
    "tail": 14
  },
  "counters": [
    {
      "name": "error",
      "pattern": "error|failed|inactive|stopped",
      "flags": "i"
    }
  ]
}
